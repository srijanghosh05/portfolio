---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

        <!-- Google Fonts: Inter, JetBrains Mono, Anton -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body class="font-inter antialiased overflow-x-hidden min-h-screen">
        <!-- Film Grain Overlay -->
        <div class="film-grain" aria-hidden="true"></div>

        <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 hidden md:flex items-center gap-5 lg:gap-8 px-6 lg:px-8 py-3 rounded-full bg-white/30 dark:bg-data-slate/80 backdrop-blur-xl border border-white/50 dark:border-gray-800 shadow-md">
            <a href="#vault" class="text-sm font-medium text-slate-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors no-underline">Vault</a>
            <a href="#experience" class="text-sm font-medium text-slate-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors no-underline">Timeline</a>
            <a href="#skills" class="text-sm font-medium text-slate-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors no-underline">Skills</a>
            <a href="#training" class="text-sm font-medium text-slate-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors no-underline">Training</a>
            <a href="#certifications" class="text-sm font-medium text-slate-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors no-underline">Certificates</a>
        </nav>

        <div class="fixed top-6 right-6 z-50">
            <button id="theme-toggle" class="p-2 rounded-full bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors" aria-label="Toggle Dark Mode">
                <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </button>
        </div>

		<slot />

        <script is:inline>
            var themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
            var themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
            var themeButton = document.getElementById('theme-toggle');

            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                themeToggleLightIcon.classList.remove('hidden');
                document.documentElement.classList.add('dark');
            } else {
                themeToggleDarkIcon.classList.remove('hidden');
                document.documentElement.classList.remove('dark');
            }

            themeButton.addEventListener('click', function() {
                themeToggleDarkIcon.classList.toggle('hidden');
                themeToggleLightIcon.classList.toggle('hidden');

                if (localStorage.getItem('color-theme')) {
                    if (localStorage.getItem('color-theme') === 'light') {
                        document.documentElement.classList.add('dark');
                        localStorage.setItem('color-theme', 'dark');
                    } else {
                        document.documentElement.classList.remove('dark');
                        localStorage.setItem('color-theme', 'light');
                    }
                } else {
                    if (document.documentElement.classList.contains('dark')) {
                        document.documentElement.classList.remove('dark');
                        localStorage.setItem('color-theme', 'light');
                    } else {
                        document.documentElement.classList.add('dark');
                        localStorage.setItem('color-theme', 'dark');
                    }
                }
            });

            // ==========================================
            // GSAP: Cinematic Kinetic Transitions
            // ==========================================
            import('https://cdn.jsdelivr.net/npm/gsap@3.12.5/+esm').then(async (gsapModule) => {
                const gsap = gsapModule.gsap || gsapModule.default;
                const { ScrollTrigger } = await import('https://cdn.jsdelivr.net/npm/gsap@3.12.5/ScrollTrigger.js/+esm');
                gsap.registerPlugin(ScrollTrigger);

                const snap = "power4.inOut";

                // Hard-cut liquid mask reveal
                document.querySelectorAll('.liquid-section').forEach((section) => {
                    gsap.to(section, {
                        clipPath: "inset(0% 0% 0% 0% round 0px)",
                        duration: 0.6,
                        ease: snap,
                        scrollTrigger: {
                            trigger: section,
                            start: "top 90%",
                            end: "top 30%",
                            scrub: 0.3,
                        }
                    });
                });

                // Kinetic headings: slow horizontal parallax drift
                document.querySelectorAll('.kinetic-heading').forEach((heading) => {
                    gsap.fromTo(heading,
                        { x: -200 },
                        {
                            x: 100,
                            ease: "none",
                            scrollTrigger: {
                                trigger: heading.closest('.liquid-section') || heading,
                                start: "top bottom",
                                end: "bottom top",
                                scrub: true,
                            }
                        }
                    );
                });

                // Chromatic pop-in cards
                document.querySelectorAll('.chromatic-pop').forEach((card) => {
                    gsap.to(card, {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 0.6,
                        ease: "back.out(1.4)",
                        scrollTrigger: {
                            trigger: card,
                            start: "top 85%",
                            toggleActions: "play none none none",
                        }
                    });
                });

                // Drop-in children
                document.querySelectorAll('.drop-child').forEach((child) => {
                    gsap.to(child, {
                        opacity: 1,
                        y: 0,
                        duration: 0.7,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: child,
                            start: "top 88%",
                            toggleActions: "play none none none",
                        }
                    });
                });

                // Wipe reveal
                document.querySelectorAll('.wipe-reveal').forEach((el) => {
                    gsap.to(el, {
                        clipPath: "inset(0 0% 0 0)",
                        duration: 0.7,
                        ease: snap,
                        scrollTrigger: {
                            trigger: el,
                            start: "top 85%",
                            toggleActions: "play none none none",
                        }
                    });
                });

                // Drifting year markers: slow vertical parallax
                document.querySelectorAll('.drift-year').forEach((year) => {
                    gsap.fromTo(year,
                        { y: 60 },
                        {
                            y: -60,
                            ease: "none",
                            scrollTrigger: {
                                trigger: year.closest('.liquid-section') || year,
                                start: "top bottom",
                                end: "bottom top",
                                scrub: true,
                            }
                        }
                    );
                });

                // Section reveal fallback
                document.querySelectorAll('.section-reveal').forEach((el) => {
                    gsap.to(el, {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 85%",
                            toggleActions: "play none none none",
                        }
                    });
                });

                // Glitch-in trigger for Bio
                const bioEl = document.querySelector('.glitch-trigger');
                if (bioEl) {
                    ScrollTrigger.create({
                        trigger: bioEl,
                        start: "top 70%",
                        onEnter: () => bioEl.classList.add('glitch-in'),
                        once: true,
                    });
                }
            });

        </script>
	</body>
</html>
