---
// Vault.astro
const projects = [
  {
    title: "Automated Cricket ETL Pipeline",
    tech: "AWS EC2/RDS",
    metric: "40% ingestion optimization",
    github: "https://github.com/srijanghosh05/Cricket-Live-Data-ETL-Pipeline"
  },
  {
    title: "Visibility Distance Prediction",
    tech: "Vectorized Processing",
    metric: "48% accuracy gain",
    github: "https://github.com/srijanghosh05/Visibility-Distance-Prediction"
  },
  {
    title: "Hand-written Digit Recognizer",
    tech: "CNN",
    metric: "15% latency reduction",
    github: "https://github.com/srijanghosh05/hand-writtern-digit-recogniser"
  }
];
---
<section id="vault" class="relative space-y-16">
  <!-- Drifting Background Title -->
  <div class="kinetic-heading text-gray-200 dark:text-white/[0.04] absolute -top-8 left-0 pointer-events-none">THE VAULT</div>

  <h3 class="text-2xl font-bold font-jetbrains tracking-tight section-reveal relative z-10">Projects <span class="text-red-600 dark:text-red-500">/></span></h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">
    {projects.map((project) => (
      <div 
        class="chromatic-pop group relative flex flex-col p-6 rounded-2xl bg-white dark:bg-[#111111] border border-gray-200 dark:border-gray-800 transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-2 hover:shadow-xl dark:hover:shadow-[0_0_25px_rgba(220,38,38,0.12)] hover:border-gray-300 dark:hover:border-red-900/50"
      >
        <div class="flex-grow space-y-4">
          <h3 class="text-xl font-semibold leading-tight text-gray-900 dark:text-white">{project.title}</h3>
          
          <div class="inline-block px-2 py-1 rounded-md bg-gray-100 dark:bg-deep-midnight border border-gray-300 dark:border-gray-700">
             <span class="text-xs font-jetbrains text-gray-800 dark:text-gray-400">{project.tech}</span>
          </div>
        </div>
        
        <div class="mt-8 pt-4 border-t border-gray-200 dark:border-gray-800 group-hover:border-gray-400 dark:group-hover:border-red-900/50 transition-colors">
          <div class="font-jetbrains text-sm text-red-600 dark:text-red-500 flex items-center justify-between">
            <span>{project.metric}</span>
            <a 
              href={project.github} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 p-1 hover:text-black dark:hover:text-white relative z-20 pointer-events-auto" 
              aria-label="View repository"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
