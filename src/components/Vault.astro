---
// Vault.astro
const projects = [
  {
    title: "Automated Cricket ETL Pipeline",
    tech: "AWS EC2/RDS",
    metric: "40% ingestion optimization",
  },
  {
    title: "Visibility Distance Prediction",
    tech: "Vectorized Processing",
    metric: "48% accuracy gain",
  },
  {
    title: "Hand-written Digit Recognizer",
    tech: "CNN",
    metric: "15% latency reduction",
  }
];
---
<section id="vault" class="space-y-16">
  <!-- Kinetic Heading -->
  <div class="overflow-hidden">
    <h2 class="kinetic-heading text-slate-200 dark:text-gray-800">THE VAULT</h2>
  </div>
  <h3 class="text-2xl font-bold font-jetbrains tracking-tight -mt-8 section-reveal">Projects <span class="text-indigo-500 dark:text-indigo-400">/></span></h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <div 
        class="drop-child group relative flex flex-col p-6 rounded-2xl bg-white/50 dark:bg-[#1A1A1A] backdrop-blur-[10px] border border-gray-200 dark:border-gray-800 transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-2 hover:shadow-lg dark:hover:shadow-[0_0_20px_rgba(99,102,241,0.15)] hover:border-gray-300 dark:hover:border-indigo-500/40"
      >
        <div class="flex-grow space-y-4">
          <h3 class="text-xl font-semibold leading-tight text-gray-900 dark:text-white">{project.title}</h3>
          
          <div class="inline-block px-2 py-1 rounded-md bg-gray-100 dark:bg-deep-midnight border border-gray-300 dark:border-gray-700">
             <span class="text-xs font-jetbrains text-gray-800 dark:text-gray-400">{project.tech}</span>
          </div>
        </div>
        
        <div class="mt-8 pt-4 border-t border-gray-200 dark:border-gray-800 group-hover:border-gray-400 dark:group-hover:border-indigo-500/50 transition-colors">
          <p class="font-jetbrains text-sm text-indigo-600 dark:text-indigo-400 flex items-center justify-between">
            {project.metric}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
