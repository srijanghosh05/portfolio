---
// Training.astro
---
<section id="training" class="space-y-16">
  <!-- Kinetic Heading -->
  <div class="overflow-hidden">
    <h2 class="kinetic-heading text-slate-200 dark:text-gray-800">TRAINING</h2>
  </div>
  <h3 class="text-2xl font-bold font-jetbrains tracking-tight -mt-8 section-reveal">Specialized Programs <span class="text-teal-500 dark:text-teal-400">/></span></h3>
  
  <div 
    class="drop-child group relative flex flex-col p-8 rounded-2xl bg-white/50 dark:bg-[#1A1A1A] backdrop-blur-[10px] border border-gray-200 dark:border-gray-800 transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-2 hover:shadow-lg dark:hover:shadow-[0_0_20px_rgba(20,184,166,0.15)] hover:border-gray-300 dark:hover:border-teal-500/40"
  >
    <div class="flex-grow space-y-4">
      <h3 class="text-2xl font-semibold leading-tight text-black dark:text-white">CSE PATHSHALA | Advance Python for AI and ML</h3>
      
      <p class="text-slate-700 dark:text-gray-400 max-w-2xl">
        Intensive training program focusing on advanced Python programming specifically tailored for Artificial Intelligence and Machine Learning applications.
      </p>
    </div>
    
    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row gap-4 sm:gap-8 transition-colors group-hover:border-gray-400 dark:group-hover:border-teal-500/50">
      <div class="flex flex-col">
        <span class="text-3xl font-bold font-jetbrains text-teal-600 dark:text-teal-400">40%</span>
        <span class="text-sm text-slate-600 dark:text-gray-400 mt-1">coding efficiency boost</span>
      </div>
      <div class="hidden sm:block w-px bg-gray-300 dark:bg-gray-800"></div>
      <div class="flex flex-col">
        <span class="text-3xl font-bold font-jetbrains text-teal-600 dark:text-teal-400">55%</span>
        <span class="text-sm text-slate-600 dark:text-gray-400 mt-1">gain in ML experimentation</span>
      </div>
    </div>
  </div>
</section>
