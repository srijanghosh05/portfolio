---
// Training.astro
---
<section id="training" class="relative space-y-16">
  <!-- Drifting Background Title -->
  <div class="kinetic-heading text-gray-200 dark:text-white/[0.04] absolute -top-8 left-0">TRAINING</div>

  <h3 class="text-2xl font-bold font-jetbrains tracking-tight section-reveal relative z-10">Specialized Programs <span class="text-red-600 dark:text-red-500">/></span></h3>
  
  <div 
    class="drop-child group relative flex flex-col p-8 rounded-2xl bg-white dark:bg-[#111111] border border-gray-200 dark:border-gray-800 transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-2 hover:shadow-xl dark:hover:shadow-[0_0_25px_rgba(220,38,38,0.1)] hover:border-gray-300 dark:hover:border-red-900/40 z-10"
  >
    <div class="flex-grow space-y-4">
      <h3 class="text-2xl font-semibold leading-tight text-black dark:text-white">CSE PATHSHALA | Advance Python for AI and ML</h3>
      
      <p class="text-slate-700 dark:text-gray-400 max-w-2xl">
        Intensive training program focusing on advanced Python programming specifically tailored for Artificial Intelligence and Machine Learning applications.
      </p>
    </div>
    
    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row gap-4 sm:gap-8 transition-colors group-hover:border-gray-400 dark:group-hover:border-red-900/40">
      <div class="flex flex-col">
        <span class="text-3xl font-bold font-jetbrains text-cyber-citrus">40%</span>
        <span class="text-sm text-slate-600 dark:text-gray-400 mt-1">coding efficiency boost</span>
      </div>
      <div class="hidden sm:block w-px bg-gray-300 dark:bg-gray-800"></div>
      <div class="flex flex-col">
        <span class="text-3xl font-bold font-jetbrains text-cyber-citrus">55%</span>
        <span class="text-sm text-slate-600 dark:text-gray-400 mt-1">gain in ML experimentation</span>
      </div>
    </div>
  </div>
</section>
