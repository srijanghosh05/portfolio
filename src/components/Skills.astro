---
// Skills.astro
const skills = {
  Languages: ["Python", "C++", "HTML", "CSS", "JavaScript"],
  "Libraries/Frameworks": ["NumPy", "Pandas", "Scikit-Learn", "TensorFlow", "Seaborn", "spaCy"],
  "Cloud & Tools": ["AWS (EC2, RDS)", "PostgreSQL", "REST APIs", "GitHub"]
};
---
<section id="skills" class="space-y-16">
  <!-- Kinetic Heading -->
  <div class="overflow-hidden">
    <h2 class="kinetic-heading text-slate-200 dark:text-gray-800">ARSENAL</h2>
  </div>
  <h3 class="text-2xl font-bold font-jetbrains tracking-tight -mt-8 section-reveal">Technical Stack <span class="text-violet-500 dark:text-violet-400">/></span></h3>
  
  <div class="space-y-10">
    {Object.entries(skills).map(([category, items]) => (
      <div class="drop-child">
        <h3 class="text-lg font-semibold text-slate-800 dark:text-gray-300 mb-4">{category}</h3>
        <div class="flex flex-wrap gap-3">
          {items.map(item => (
            <div class="px-4 py-2 rounded-full bg-white/50 dark:bg-[#1A1A1A] border border-gray-200 dark:border-gray-800 text-sm font-medium text-slate-900 dark:text-violet-300 transition-all hover:-translate-y-1 hover:shadow-md dark:hover:shadow-[0_0_15px_rgba(139,92,246,0.15)] dark:hover:border-violet-500/40">
              {item}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
