---
// Experience.astro
const history = [
  {
    role: "B.Tech (CSE - AI & ML)",
    company: "Lovely Professional University",
    team: "Education",
    type: "Education",
    date: "2023-2027",
    year: "2027",
  },
  {
    role: "Content Manager",
    company: "AccentureEmph",
    team: "Digital Strategy & Communication",
    type: "Experience",
    date: "2023-2024",
    year: "2024",
  },
  {
    role: "Senior Secondary School",
    company: "D.A.V. Public School",
    team: "Education",
    type: "Education",
    date: "2021-2022",
    year: "2022",
  },
  {
    role: "Secondary School",
    company: "D.A.V. Public School",
    team: "Education",
    type: "Education",
    date: "2019-2020",
    year: "2020",
  }
];
---
<section id="experience" class="relative space-y-16 pt-8">
  <!-- Drifting Background Title -->
  <div class="kinetic-heading text-gray-200 dark:text-white/[0.04] absolute top-0 left-0">TIMELINE</div>

  <h3 class="text-2xl font-bold font-jetbrains tracking-tight section-reveal relative z-10">Experience & Education <span class="text-red-600 dark:text-red-500">/></span></h3>

  <div class="relative ml-4 space-y-20 z-10">
    {history.map((item) => (
      <div class="relative pl-10 drop-child">
        <!-- Drifting Year Marker (behind card) -->
        <div class="drift-year -left-4 top-0 text-gray-100 dark:text-white/[0.03]">{item.year}</div>

        <!-- Timeline line + node -->
        <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-800"></div>
        <div class="absolute left-[-4px] top-2 w-3 h-3 rounded-full bg-red-600 dark:bg-red-500 shadow-[0_0_10px_rgba(220,38,38,0.4)]"></div>
        
        <div class="relative space-y-3">
          <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{item.role}</h3>
            <span class="text-xs font-jetbrains text-red-600 dark:text-red-400">{item.date}</span>
          </div>
          
          <div class="wipe-reveal text-slate-700 dark:text-gray-400">
            <span class="text-slate-900 dark:text-white font-bold">{item.company}</span>
            <span class="mx-2 text-slate-400 dark:text-gray-600">|</span>
            <span class="text-slate-700 dark:text-gray-400">{item.team}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
