---
// Experience.astro
const history = [
  {
    role: "B.Tech (CSE - AI & ML)",
    company: "Lovely Professional University",
    team: "Education",
    type: "Education",
    date: "2023-2027",
  },
  {
    role: "Content Manager",
    company: "AccentureEmph",
    team: "Digital Strategy & Communication",
    type: "Experience",
    date: "2023-2024",
  },
  {
    role: "Senior Secondary (XII)",
    company: "D.A.V. Public School",
    team: "Education",
    type: "Education",
    date: "2021-2022",
  },
  {
    role: "Secondary (X)",
    company: "D.A.V. Public School",
    team: "Education",
    type: "Education",
    date: "2019-2020",
  }
];
---
<section id="experience" class="space-y-16">
  <!-- Kinetic Heading -->
  <div class="overflow-hidden">
    <h2 class="kinetic-heading text-slate-200 dark:text-gray-800">TIMELINE</h2>
  </div>
  <h3 class="text-2xl font-bold font-jetbrains tracking-tight -mt-8 section-reveal">Experience & Education <span class="text-amber-500 dark:text-amber-400">/></span></h3>

  <div class="relative border-l-2 border-gray-200 dark:border-gray-800 ml-4 space-y-16">
    {history.map((item) => (
      <div class="relative pl-8 drop-child">
        <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-amber-500 dark:bg-amber-400 shadow-[0_0_10px_rgba(245,158,11,0.3)] dark:shadow-[0_0_10px_rgba(251,191,36,0.5)]"></div>
        
        <div class="space-y-3">
          <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{item.role}</h3>
            <span class="text-xs font-jetbrains text-amber-600 dark:text-amber-400/80">{item.date}</span>
          </div>
          
          <div class="wipe-reveal text-slate-700 dark:text-gray-400">
            <span class="text-slate-900 dark:text-white font-bold transition-colors duration-300">{item.company}</span>
            <span class="mx-2 text-slate-400 dark:text-gray-600">|</span>
            <span class="text-slate-700 dark:text-gray-400">{item.team}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
