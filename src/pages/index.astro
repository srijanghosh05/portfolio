---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Bio from '../components/Bio.astro';
import Vault from '../components/Vault.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Training from '../components/Training.astro';
import Certifications from '../components/Certifications.astro';
---

<Layout title="Srijan Ghosh | Data Engineer & AI Specialist">
	<Hero />

	<!-- Cinematic Sections: High-contrast color blocks -->
	<div class="liquid-section bg-gray-50 dark:bg-[#0a0a0a] h-screen" id="vault">
		<div class="h-full flex flex-col justify-center py-24 px-6">
			<div class="max-w-5xl mx-auto w-full">
				<Vault />
			</div>
		</div>
	</div>

	<div class="liquid-section bg-white dark:bg-[#1a0000] h-screen" id="experience">
		<div class="h-full flex flex-col justify-center py-24 px-6">
			<div class="max-w-5xl mx-auto w-full">
				<Experience />
			</div>
		</div>
	</div>

	<div class="liquid-section bg-gray-100 dark:bg-[#0d0d0d] h-screen" id="skills">
		<div class="h-full flex flex-col justify-center py-24 px-6">
			<div class="max-w-5xl mx-auto w-full">
				<Skills />
			</div>
		</div>
	</div>

	<div class="liquid-section bg-gray-50 dark:bg-[#0a0a0a] h-screen" id="training">
		<div class="h-full flex flex-col justify-center py-24 px-6">
			<div class="max-w-5xl mx-auto w-full">
				<Training />
			</div>
		</div>
	</div>

	<div class="liquid-section bg-white dark:bg-[#111111] h-screen" id="certifications">
		<div class="h-full flex flex-col justify-center py-24 px-6">
			<div class="max-w-5xl mx-auto w-full">
				<Certifications />
			</div>
		</div>
	</div>
</Layout>
